# ===== QQ Bot 配置 ==== 复制为 .env 后填入 ====

# 平台名称（随便取）
QQBOT_NAME=deepseek

# API 地址（填你要连的中转站/官方 API）
QQBOT_API_BASE=https://api.deepseek.com

# API 密钥
QQBOT_API_KEY=sk-your-api-key-here

# ---- 以下都是可选 ----
# QQBOT_MODEL=deepseek-chat       # 模型名，留空则自动获取
# QQBOT_ADMIN_QQS=123456789       # 管理员 QQ 号（逗号分隔）
# NAPCTAT_DIR=D:\\napcat          # NapCatQQ 安装路径（启动器用）
